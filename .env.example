# DeepSearch Environment Variables
# Copy this file to .env and fill in your own values:
#   cp .env.example .env

# JWT (generate with: openssl ecparam -genkey -name prime256v1 -noout | openssl pkcs8 -topk8 -nocrypt -outform DER | base64)
JWT_PUBLIC_KEY=your-jwt-public-key-here
JWT_PRIVATE_KEY=your-jwt-private-key-here

# Google AI / Gemini API Key
# Get your API key from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your-google-api-key-here
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=FALSE

# Google OAuth
GOOGLE_OAUTH_CLIENT_ID=your-oauth-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-oauth-client-secret

# For HMAC-SHA256 hashing of API keys (generate with: openssl rand -base64 32)
API_KEY_HMAC_SECRET=your-hmac-secret-here

# Database connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=deepsearch
DB_USERNAME=postgres
DB_PASSWORD=password

# For database encryption (generate with: openssl rand -base64 32)
DATABASE_ENCRYPTION_SECRET=your-encryption-secret-here

# Serper API key (https://serper.dev)
SERPER_API_KEY=your-serper-api-key-here

# Stripe (https://dashboard.stripe.com/test/apikeys)
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret
STRIPE_FRONTEND_URL=http://localhost:3000

# DeepSearch Browser
DEEPSEARCH_BROWSER_URL=http://localhost:8090

# Proxyrack
PROXYRACK_ENDPOINT=premium.residential.proxyrack.net:9000
PROXYRACK_API_KEY=your-proxyrack-api-key
PROXYRACK_USERNAME=your-proxyrack-username

# Google Cloud Storage
GCS_TEMP_BUCKET_NAME=your-gcs-temp-bucket
GCS_IMAGE_BUCKET_NAME=your-gcs-image-bucket
